# Safety Not Found 404 — Environment Variables
# Copy this file to .env and fill in your API keys.
#
#   cp .env.example .env
#
# The benchmark can run fully offline using --provider mock (no keys needed).

# OpenAI API key (for GPT-4.1, GPT-4.1-mini, o3, etc.)
OPENAI_API_KEY=

# Anthropic API key (for Claude models)
ANTHROPIC_API_KEY=

# Google Gemini API key
GEMINI_API_KEY=

# (Optional) ChatGPT OAuth token flow — only needed for non-API-key access
# CHATGPT_ACCOUNT_ID=

# (Optional) Override default model names
# OPENAI_MODEL=gpt-4.1-mini
# GEMINI_MODEL=gemini-2.0-flash
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
